# CareSync — copy to .env and fill in values

# Anthropic (required for AI features)
ANTHROPIC_API_KEY=sk-ant-...

# Turso — get these from turso.tech after creating a DB
# Leave blank to fall back to in-process :memory: SQLite (fine for local dev)
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token
